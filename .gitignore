# Rust build artifacts
target/

# Python compiled extensions and debug symbols
*.pyd
*.so
*.pdb

# Distribution / packaging
dist/
*.egg-info/
*.whl

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Runtime scratch dirs used during development
tmp/
save/

# Test cache
.pytest_cache/
.coverage
htmlcov/

# Ruff linter cache
.ruff_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# SlapPyEngine asset files (keep example ones)
*.slap
!SlapPyEngineExamples/examples/**/*.slap

# Visual test output (generated PNGs and videos, not committed)
SlapPyEngineTests/tests/visual/output/
SlapPyEngineTests/tests/output/

# Audit / profiling artefacts (regenerated on demand)
_audit_snapshots/
_prof_*.py
*.bak

# Visual diff outputs from the harness
docs/visual_diffs/

# Generated example outputs (gallery artefacts re-included below)
SlapPyEngineExamples/examples/output/**
!SlapPyEngineExamples/examples/output/hello_gi/hello_gi.png
!SlapPyEngineExamples/examples/output/humanoid/humanoid_ik_terrain.gif
!SlapPyEngineExamples/examples/output/humanoid/humanoid_walking.gif
!SlapPyEngineExamples/examples/output/ragdoll/hello_ragdoll.gif
!SlapPyEngineExamples/examples/output/rope/hello_rope.png
!SlapPyEngineExamples/examples/output/studio/hello_studio.gif

# Legacy example regeneration target
SlapPyEngineExamples/examples/legacy/output/

# UI concept art — reference assets, always tracked
!UIConceptArt/*.jfif
!UIConceptArt/*.png
