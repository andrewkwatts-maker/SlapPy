# Rust build artifacts
target/

# Python compiled extensions and debug symbols
*.pyd
*.so
*.pdb

# Distribution / packaging
dist/
*.egg-info/
*.whl

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Runtime scratch dirs used during development
tmp/
save/

# Orphan pre-rename copies of the test/example dirs. The tracked
# location is PharosEngineTests/ + PharosEngineExamples/ (Sprint 3
# rename). Local checkouts that predate the rename may still hold
# __pycache__/output leftovers here — ignore them.
SlapPyEngineTests/
SlapPyEngineExamples/

# Local scratch scripts
new_script_*.py

# Test cache
.pytest_cache/
.coverage
htmlcov/

# Ruff linter cache
.ruff_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Pharos Engine asset files (keep example ones)
*.slap
!PharosEngineExamples/examples/**/*.slap

# Visual test output (generated PNGs and videos, not committed)
PharosEngineTests/tests/visual/output/
PharosEngineTests/tests/output/

# Audit / profiling artefacts (regenerated on demand)
_audit_snapshots/
_prof_*.py
*.bak

# Visual diff outputs from the harness
docs/visual_diffs/

# Generated example outputs (gallery artefacts re-included below)
PharosEngineExamples/examples/output/**
!PharosEngineExamples/examples/output/hello_gi/hello_gi.png
!PharosEngineExamples/examples/output/humanoid/humanoid_ik_terrain.gif
!PharosEngineExamples/examples/output/humanoid/humanoid_walking.gif
!PharosEngineExamples/examples/output/ragdoll/hello_ragdoll.gif
!PharosEngineExamples/examples/output/rope/hello_rope.png
!PharosEngineExamples/examples/output/studio/hello_studio.gif

# Legacy example regeneration target
PharosEngineExamples/examples/legacy/output/

# UI concept art — reference assets, always tracked
!UIConceptArt/*.jfif
!UIConceptArt/*.png
